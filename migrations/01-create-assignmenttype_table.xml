<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog 
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.0.xsd">

   <changeSet id="create-assignmenttype" author="Caiden Sunlin">
        <createTable tableName="assignmenttype">

            <column name="id" type="Integer" autoIncrement="true" startWith="100">
                <constraints primaryKey="true"/>
            </column>

            <column name="name" type="varchar(64)">
                <constraints nullable="false" unique="true"/>
            </column>

        </createTable>
   </changeSet>

   <changeSet id="populate-assignmenttype" author="Caiden Sunlin">
    <insert tableName="assignmenttype">
        <column name="name" value="Homework"></column>
    </insert>
    <insert tableName="assignmenttype">
        <column name="name" value="Exam"></column>
    </insert>
    <insert tableName="assignmenttype">
        <column name="name" value="Project"></column>
    </insert>
    <insert tableName="assignmenttype">
        <column name="name" value="Quiz"></column>
    </insert>
    <insert tableName="assignmenttype">
        <column name="name" value="in-class"></column>
    </insert>

    <rollback>
        <delete tableName="assignmenttype">
            <where>name = 'Homework'</where>
        </delete>
         <delete tableName="assignmenttype">
            <where>name = 'Exam'</where>
        </delete>
         <delete tableName="assignmenttype">
            <where>name = 'Project'</where>
        </delete>
         <delete tableName="assignmenttype">
            <where>name = 'Quiz'</where>
        </delete>
         <delete tableName="assignmenttype">
            <where>name = 'in-class'</where>
        </delete>
    </rollback>
   </changeSet>

</databaseChangeLog>